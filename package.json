{
  "name": "rigmateapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "build:github-pages": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "deploy:github-pages": "npm run build:github-pages",
    "pages:build": "opennextjs-cloudflare build",
    "pages:deploy": "opennextjs-cloudflare build && wrangler deploy",
    "pages:preview": "opennextjs-cloudflare build && wrangler dev",
    "cf:build": "opennextjs-cloudflare build",
    "db:seed": "node --experimental-transform-types prisma/seed.ts",
    "db:migrate": "npx prisma migrate dev",
    "db:studio": "npx prisma studio"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@prisma/adapter-d1": "^7.8.0",
